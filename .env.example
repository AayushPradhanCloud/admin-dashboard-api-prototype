# --- App ---
NODE_ENV=development
SERVICE_NAME=generic-api
APP_PORT=3000
API_PREFIX=v1
LOG_LEVEL=debug

# --- Database (Postgres) ---
DATABASE_URL=postgresql://generic:generic@localhost:5432/generic?schema=public

# --- Keycloak (external — point at your hosted Keycloak instance) ---
# Base URL of your Keycloak server (no trailing slash)
KEYCLOAK_BASE_URL=https://auth.example.com
# The realm configured for this application
KEYCLOAK_REALM=my-realm
# Confidential client ID registered in Keycloak for this API
KEYCLOAK_CLIENT_ID=my-api
# Client secret from Keycloak → Clients → Credentials tab
KEYCLOAK_CLIENT_SECRET=replace-with-your-client-secret
# JWKS endpoint — used for local JWT signature validation (no per-request introspection)
KEYCLOAK_JWKS_URL=https://auth.example.com/realms/my-realm/protocol/openid-connect/certs
# Token issuer — must match the `iss` claim in incoming JWTs
KEYCLOAK_ISSUER=https://auth.example.com/realms/my-realm

# --- Redis (optional cache) ---
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=false

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Observability (off by default locally) ---
SENTRY_DSN=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY

# --- Throttling ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- Feature flags (DB-backed; comma-separated overrides) ---
FEATURE_FLAGS_OVERRIDES=

# --- NATS ---
NATS_URL=nats://localhost:4222
NATS_STREAM=NUERA_ENROLLMENT
NATS_DURABLE=admin-dashboard
NATS_FILTER_SUBJECT=enrollment.application.*
NATS_SUBJECT_INITIATED=enrollment.application.initiated
NATS_SUBJECT_SUBMITTED=enrollment.application.submitted
NATS_SUBJECT_DOCUMENT_RECEIVED=enrollment.application.document-received
NATS_SUBJECT_SUPPORT_REQUESTED=enrollment.application.support-requested
