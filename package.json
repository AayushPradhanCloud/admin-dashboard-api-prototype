{
  "name": "nest-api-boilerplate",
  "version": "0.1.0",
  "description": "nest NestJS boilerplate — hexagonal/DDD/CQRS/event-driven, strict TypeScript, Prisma, Keycloak.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/infrastructure/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --config jest.config.ts",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate --schema=./prisma/schema",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema",
    "prisma:migrate:down": "ts-node scripts/prisma-migrate-down.ts",
    "prisma:deploy": "prisma migrate deploy --schema=./prisma/schema",
    "prisma:studio": "prisma studio --schema=./prisma/schema",
    "prisma:seed": "ts-node prisma/seed.ts",
    "openapi:generate": "ts-node scripts/generate-openapi.ts",
    "postman:generate": "openapi2postmanv2 -s openapi.json -o postman-collection.json -p",
    "audit": "pnpm audit --audit-level=high",
    "prepare": "husky"
  },
  "dependencies": {
    "@codegenie/serverless-express": "^4.16.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^5.18.0",
    "@sentry/nestjs": "^8.26.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "jose": "^5.6.3",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@faker-js/faker": "^8.4.1",
    "@nestjs/cli": "^10.4.4",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.3.10",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.15",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.8",
    "nock": "^13.5.4",
    "openapi-to-postmanv2": "^4.24.0",
    "prettier": "^3.3.3",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.10.4",
    "ts-jest": "^29.2.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  }
}
