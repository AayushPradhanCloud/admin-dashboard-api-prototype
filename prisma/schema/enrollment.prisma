/// An enrollment application owned by the benefit-store enrollment API.
/// Rows are projected from inbound NATS events (`enrollment.application.initiated`
/// and `.submitted`). `enrollmentId` is the cross-service correlation key.
model Enrollment {
  id              String    @id @default(uuid()) @db.Uuid
  enrollmentId    String    @unique @map("enrollment_id")
  planId          String    @map("plan_id")
  applicantId     String?   @map("applicant_id")
  status          String // INITIATED | SUBMITTED
  referenceNumber String?   @map("reference_number")
  initiatedAt     DateTime? @map("initiated_at")
  submittedAt     DateTime? @map("submitted_at")
  source          String? // which upstream service emitted the event

  // Audit + soft delete (populated by Prisma client extension; see PrismaService).
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([status])
  @@index([deletedAt])
  @@map("enrollments")
}
